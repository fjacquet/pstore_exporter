{
  "title": "PowerStore — Cluster Overview",
  "uid": "pstore-cluster-overview",
  "tags": ["powerstore", "pstore_exporter", "block"],
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "array",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(powerstore_up, array)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Arrays Up",
      "type": "stat",
      "description": "1 = UP (green), 0 = DOWN (red) per array.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "UP",   "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "expr": "powerstore_up{array=~\"$array\"}",
          "legendFormat": "{{array}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Bulk API Enabled",
      "type": "stat",
      "description": "1 = bulk API active, 0 = per-entity polling.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Disabled", "color": "orange" } } },
            { "type": "value", "options": { "1": { "text": "Enabled",  "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "orange", "value": null },
              { "color": "green",  "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "expr": "powerstore_array_bulk_api{array=~\"$array\"}",
          "legendFormat": "{{array}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Total IOPS",
      "type": "timeseries",
      "description": "Sum of appliance total IOPS per array.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "iops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (array) (powerstore_appliance_total_iops{array=~\"$array\"})",
          "legendFormat": "{{array}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Bandwidth (read / write)",
      "type": "timeseries",
      "description": "Aggregate read and write bandwidth across all appliances.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (array) (powerstore_appliance_read_bandwidth_bytes_per_second{array=~\"$array\"})",
          "legendFormat": "{{array}} read"
        },
        {
          "refId": "B",
          "expr": "sum by (array) (powerstore_appliance_write_bandwidth_bytes_per_second{array=~\"$array\"})",
          "legendFormat": "{{array}} write"
        }
      ]
    },
    {
      "id": 5,
      "title": "Avg Latency (µs)",
      "type": "timeseries",
      "description": "Average read and write latency across all appliances.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "µs" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "avg by (array) (powerstore_appliance_read_latency_microseconds{array=~\"$array\"})",
          "legendFormat": "{{array}} read"
        },
        {
          "refId": "B",
          "expr": "avg by (array) (powerstore_appliance_write_latency_microseconds{array=~\"$array\"})",
          "legendFormat": "{{array}} write"
        }
      ]
    },
    {
      "id": 6,
      "title": "Capacity Used %",
      "type": "gauge",
      "description": "Physical used / physical total across all appliances in the selected arrays.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red",    "value": 85 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(powerstore_appliance_physical_used_bytes{array=~\"$array\"}) / sum(powerstore_appliance_physical_total_bytes{array=~\"$array\"})",
          "legendFormat": "Capacity Used %"
        }
      ]
    }
  ]
}
