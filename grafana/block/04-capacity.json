{
  "title": "PowerStore — Capacity",
  "uid": "pstore-capacity",
  "tags": ["powerstore", "pstore_exporter", "block", "capacity"],
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "array",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(powerstore_up, array)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Physical Space — Used vs Total (stacked)",
      "type": "timeseries",
      "description": "Stacked physical used (solid) and total capacity per appliance.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "stacking": { "mode": "normal" } }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (appliance_name) (powerstore_appliance_physical_used_bytes{array=~\"$array\"})",
          "legendFormat": "{{appliance_name}} used"
        },
        {
          "refId": "B",
          "expr": "sum by (appliance_name) (powerstore_appliance_physical_total_bytes{array=~\"$array\"}) - sum by (appliance_name) (powerstore_appliance_physical_used_bytes{array=~\"$array\"})",
          "legendFormat": "{{appliance_name}} free"
        }
      ]
    },
    {
      "id": 2,
      "title": "Logical Space — Provisioned vs Used",
      "type": "timeseries",
      "description": "Logical provisioned and logical used bytes per appliance.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (appliance_name) (powerstore_appliance_logical_provisioned_bytes{array=~\"$array\"})",
          "legendFormat": "{{appliance_name}} provisioned"
        },
        {
          "refId": "B",
          "expr": "sum by (appliance_name) (powerstore_appliance_logical_used_bytes{array=~\"$array\"})",
          "legendFormat": "{{appliance_name}} used"
        }
      ]
    },
    {
      "id": 3,
      "title": "Data Reduction Ratio",
      "type": "stat",
      "description": "Data reduction ratio per appliance (higher is better).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value" },
      "targets": [
        {
          "refId": "A",
          "expr": "avg by (appliance_name) (powerstore_appliance_data_reduction_ratio{array=~\"$array\"})",
          "legendFormat": "{{appliance_name}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Efficiency Ratio",
      "type": "stat",
      "description": "Overall storage efficiency ratio per appliance.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value" },
      "targets": [
        {
          "refId": "A",
          "expr": "avg by (appliance_name) (powerstore_appliance_efficiency_ratio{array=~\"$array\"})",
          "legendFormat": "{{appliance_name}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Snapshot Savings Ratio",
      "type": "stat",
      "description": "Snapshot savings ratio per appliance.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value" },
      "targets": [
        {
          "refId": "A",
          "expr": "avg by (appliance_name) (powerstore_appliance_snapshot_savings_ratio{array=~\"$array\"})",
          "legendFormat": "{{appliance_name}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Thin Savings Ratio",
      "type": "stat",
      "description": "Thin provisioning savings ratio per appliance.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value" },
      "targets": [
        {
          "refId": "A",
          "expr": "avg by (appliance_name) (powerstore_appliance_thin_savings_ratio{array=~\"$array\"})",
          "legendFormat": "{{appliance_name}}"
        }
      ]
    }
  ]
}
