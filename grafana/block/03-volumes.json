{
  "title": "PowerStore — Volumes (Top 10)",
  "uid": "pstore-volumes",
  "tags": ["powerstore", "pstore_exporter", "block", "volume"],
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "array",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(powerstore_up, array)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Top 10 Volumes — Total IOPS",
      "type": "timeseries",
      "description": "Top 10 volumes by total IOPS.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "iops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (volume_name) (powerstore_volume_total_iops{array=~\"$array\"}))",
          "legendFormat": "{{volume_name}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Top 10 Volumes — Read Latency (µs)",
      "type": "timeseries",
      "description": "Top 10 volumes by read latency.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "µs" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (volume_name) (powerstore_volume_read_latency_microseconds{array=~\"$array\"}))",
          "legendFormat": "{{volume_name}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Top 10 Volumes — Write Latency (µs)",
      "type": "timeseries",
      "description": "Top 10 volumes by write latency.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "µs" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (volume_name) (powerstore_volume_write_latency_microseconds{array=~\"$array\"}))",
          "legendFormat": "{{volume_name}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Avg IO Size by Volume",
      "type": "table",
      "description": "Average IO size in bytes for each volume.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": { "unit": "bytes" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          }
        ]
      },
      "options": {
        "sortBy": [{ "displayName": "Value", "desc": true }]
      },
      "targets": [
        {
          "refId": "A",
          "expr": "avg by (volume_name, appliance_name) (powerstore_volume_avg_io_size_bytes{array=~\"$array\"})",
          "legendFormat": "{{volume_name}}",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "labelsToFields", "options": { "valueLabel": "volume_name" } },
        { "id": "organize", "options": {} }
      ]
    }
  ]
}
