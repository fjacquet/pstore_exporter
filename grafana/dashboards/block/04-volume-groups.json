{
  "title": "PowerStore — Volume Groups",
  "uid": "pstore-volume-groups",
  "tags": ["powerstore", "pstore_exporter", "volume"],
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "timezone": "browser",
  "links": [
    {
      "title": "PowerStore dashboards",
      "type": "dashboards",
      "tags": ["powerstore"],
      "asDropdown": true,
      "includeVars": true,
      "keepTime": true,
      "icon": "external link"
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "array",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(powerstore_up, array)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Performance",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 1,
      "title": "Total IOPS per Volume Group",
      "type": "timeseries",
      "description": "Sum of total IOPS per volume group. Gauge values — aggregate with sum, never rate().",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": { "unit": "iops", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (volume_group_name) (powerstore_volume_group_total_iops{array=~\"$array\"})",
          "legendFormat": "{{volume_group_name}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Bandwidth (read / write) per Volume Group",
      "type": "timeseries",
      "description": "Read and write bandwidth per volume group.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "fieldConfig": {
        "defaults": { "unit": "Bps", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": "/ read$/" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } } ] },
          { "matcher": { "id": "byRegexp", "options": "/ write$/" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } } ] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum by (volume_group_name) (powerstore_volume_group_read_bandwidth_bytes_per_second{array=~\"$array\"})", "legendFormat": "{{volume_group_name}} read" },
        { "refId": "B", "expr": "sum by (volume_group_name) (powerstore_volume_group_write_bandwidth_bytes_per_second{array=~\"$array\"})", "legendFormat": "{{volume_group_name}} write" }
      ]
    },
    {
      "id": 3,
      "title": "Latency (read / write) per Volume Group",
      "type": "timeseries",
      "description": "Read and write latency per volume group.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "µs",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1000 }, { "color": "red", "value": 3000 } ] }
        },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": "/ read$/" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } } ] },
          { "matcher": { "id": "byRegexp", "options": "/ write$/" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } } ] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "avg by (volume_group_name) (powerstore_volume_group_read_latency_microseconds{array=~\"$array\"})", "legendFormat": "{{volume_group_name}} read" },
        { "refId": "B", "expr": "avg by (volume_group_name) (powerstore_volume_group_write_latency_microseconds{array=~\"$array\"})", "legendFormat": "{{volume_group_name}} write" }
      ]
    },
    {
      "id": 101,
      "type": "row",
      "title": "Summary",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false
    },
    {
      "id": 4,
      "title": "Volume Groups — Current Values",
      "type": "table",
      "description": "Current performance values per volume group (instant queries joined by volume_group_name).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "cellOptions": { "type": "auto" } } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Total IOPS" }, "properties": [ { "id": "unit", "value": "iops" } ] },
          { "matcher": { "id": "byName", "options": "Read Bandwidth" }, "properties": [ { "id": "unit", "value": "Bps" } ] },
          { "matcher": { "id": "byName", "options": "Write Bandwidth" }, "properties": [ { "id": "unit", "value": "Bps" } ] },
          { "matcher": { "id": "byName", "options": "Read Latency" }, "properties": [ { "id": "unit", "value": "µs" }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1000 }, { "color": "red", "value": 3000 } ] } }, { "id": "custom.cellOptions", "value": { "type": "color-text" } } ] },
          { "matcher": { "id": "byName", "options": "Write Latency" }, "properties": [ { "id": "unit", "value": "µs" }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1000 }, { "color": "red", "value": 3000 } ] } }, { "id": "custom.cellOptions", "value": { "type": "color-text" } } ] },
          { "matcher": { "id": "byName", "options": "Avg IO Size" }, "properties": [ { "id": "unit", "value": "bytes" } ] }
        ]
      },
      "options": { "showHeader": true, "cellHeight": "sm" },
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": {
              "volume_group_name": "Volume Group",
              "Value #A": "Total IOPS",
              "Value #B": "Read Bandwidth",
              "Value #C": "Write Bandwidth",
              "Value #D": "Read Latency",
              "Value #E": "Write Latency",
              "Value #F": "Avg IO Size"
            }
          }
        }
      ],
      "targets": [
        { "refId": "A", "format": "table", "instant": true, "expr": "sum by (volume_group_name) (powerstore_volume_group_total_iops{array=~\"$array\"})", "legendFormat": "{{volume_group_name}}" },
        { "refId": "B", "format": "table", "instant": true, "expr": "sum by (volume_group_name) (powerstore_volume_group_read_bandwidth_bytes_per_second{array=~\"$array\"})", "legendFormat": "{{volume_group_name}}" },
        { "refId": "C", "format": "table", "instant": true, "expr": "sum by (volume_group_name) (powerstore_volume_group_write_bandwidth_bytes_per_second{array=~\"$array\"})", "legendFormat": "{{volume_group_name}}" },
        { "refId": "D", "format": "table", "instant": true, "expr": "avg by (volume_group_name) (powerstore_volume_group_read_latency_microseconds{array=~\"$array\"})", "legendFormat": "{{volume_group_name}}" },
        { "refId": "E", "format": "table", "instant": true, "expr": "avg by (volume_group_name) (powerstore_volume_group_write_latency_microseconds{array=~\"$array\"})", "legendFormat": "{{volume_group_name}}" },
        { "refId": "F", "format": "table", "instant": true, "expr": "avg by (volume_group_name) (powerstore_volume_group_avg_io_size_bytes{array=~\"$array\"})", "legendFormat": "{{volume_group_name}}" }
      ]
    }
  ]
}
