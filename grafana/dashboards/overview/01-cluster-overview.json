{
  "title": "PowerStore — Cluster Overview",
  "uid": "pstore-cluster-overview",
  "tags": ["powerstore", "pstore_exporter", "overview"],
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "timezone": "browser",
  "links": [
    {
      "title": "PowerStore dashboards",
      "type": "dashboards",
      "tags": ["powerstore"],
      "asDropdown": true,
      "includeVars": true,
      "keepTime": true,
      "icon": "external link"
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "array",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(powerstore_up, array)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Performance",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 1,
      "title": "Total IOPS",
      "type": "timeseries",
      "description": "Sum of appliance total IOPS per array. Gauge values — aggregate with sum, never rate().",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": { "unit": "iops", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (array) (powerstore_appliance_total_iops{array=~\"$array\"})",
          "legendFormat": "{{array}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Bandwidth (read / write)",
      "type": "timeseries",
      "description": "Aggregate read and write bandwidth across all appliances per array.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "fieldConfig": {
        "defaults": { "unit": "Bps", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": "/ read$/" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } } ] },
          { "matcher": { "id": "byRegexp", "options": "/ write$/" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } } ] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum by (array) (powerstore_appliance_read_bandwidth_bytes_per_second{array=~\"$array\"})", "legendFormat": "{{array}} read" },
        { "refId": "B", "expr": "sum by (array) (powerstore_appliance_write_bandwidth_bytes_per_second{array=~\"$array\"})", "legendFormat": "{{array}} write" }
      ]
    },
    {
      "id": 3,
      "title": "Avg Latency (read / write)",
      "type": "timeseries",
      "description": "Average read and write latency across all appliances per array.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "µs",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1000 }, { "color": "red", "value": 3000 } ] }
        },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": "/ read$/" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } } ] },
          { "matcher": { "id": "byRegexp", "options": "/ write$/" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } } ] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "avg by (array) (powerstore_appliance_read_latency_microseconds{array=~\"$array\"})", "legendFormat": "{{array}} read" },
        { "refId": "B", "expr": "avg by (array) (powerstore_appliance_write_latency_microseconds{array=~\"$array\"})", "legendFormat": "{{array}} write" }
      ]
    },
    {
      "id": 101,
      "type": "row",
      "title": "Capacity",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false
    },
    {
      "id": 4,
      "title": "Capacity Used %",
      "type": "gauge",
      "description": "Cluster physical used / physical total across the selected arrays.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 85 } ] },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "refId": "A", "expr": "100 * sum by (array) (powerstore_cluster_physical_used_bytes{array=~\"$array\"}) / sum by (array) (powerstore_cluster_physical_total_bytes{array=~\"$array\"})", "legendFormat": "{{array}}" }
      ]
    },
    {
      "id": 5,
      "title": "Physical Space — Used vs Total",
      "type": "timeseries",
      "description": "Cluster physical capacity rollup (SpaceMetricsByCluster).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 10, "x": 6, "y": 10 },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 15, "showPoints": "never" } },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": "/ total$/" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } } ] },
          { "matcher": { "id": "byRegexp", "options": "/ used$/" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } } ] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum by (array) (powerstore_cluster_physical_total_bytes{array=~\"$array\"})", "legendFormat": "{{array}} total" },
        { "refId": "B", "expr": "sum by (array) (powerstore_cluster_physical_used_bytes{array=~\"$array\"})", "legendFormat": "{{array}} used" }
      ]
    },
    {
      "id": 6,
      "title": "Data Reduction Ratio",
      "type": "stat",
      "description": "Cluster data-reduction ratio (N:1).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 10 },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 2, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "textMode": "auto" },
      "targets": [
        { "refId": "A", "expr": "avg by (array) (powerstore_cluster_data_reduction_ratio{array=~\"$array\"})", "legendFormat": "{{array}}" }
      ]
    },
    {
      "id": 7,
      "title": "Efficiency Ratio",
      "type": "stat",
      "description": "Overall cluster efficiency ratio (N:1).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 10 },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 2, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "textMode": "auto" },
      "targets": [
        { "refId": "A", "expr": "avg by (array) (powerstore_cluster_efficiency_ratio{array=~\"$array\"})", "legendFormat": "{{array}}" }
      ]
    },
    {
      "id": 8,
      "title": "Logical Space — Provisioned vs Used",
      "type": "timeseries",
      "description": "Cluster logical provisioned vs logical used (over-provisioning view).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 14 },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 15, "showPoints": "never" } },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": "/ provisioned$/" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } } ] },
          { "matcher": { "id": "byRegexp", "options": "/ used$/" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } } ] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum by (array) (powerstore_cluster_logical_provisioned_bytes{array=~\"$array\"})", "legendFormat": "{{array}} provisioned" },
        { "refId": "B", "expr": "sum by (array) (powerstore_cluster_logical_used_bytes{array=~\"$array\"})", "legendFormat": "{{array}} used" }
      ]
    }
  ]
}
