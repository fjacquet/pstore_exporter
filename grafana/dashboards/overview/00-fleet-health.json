{
  "title": "PowerStore — Fleet Health",
  "uid": "pstore-fleet-health",
  "tags": ["powerstore", "pstore_exporter", "overview"],
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "timezone": "browser",
  "links": [
    {
      "title": "PowerStore dashboards",
      "type": "dashboards",
      "tags": ["powerstore"],
      "asDropdown": true,
      "includeVars": true,
      "keepTime": true,
      "icon": "external link"
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "array",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(powerstore_up, array)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Status",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 1,
      "title": "Arrays Up",
      "type": "stat",
      "description": "Per-array reachability. The header dropdown navigates to all PowerStore dashboards (the hub mechanism).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "value_and_name" },
      "targets": [
        { "refId": "A", "expr": "powerstore_up{array=~\"$array\"}", "legendFormat": "{{array}}" }
      ]
    },
    {
      "id": 2,
      "title": "Scrape Staleness",
      "type": "stat",
      "description": "Seconds since last successful scrape per array.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 90 }, { "color": "red", "value": 300 } ] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "value_and_name" },
      "targets": [
        { "refId": "A", "expr": "time() - powerstore_last_scrape_timestamp_seconds{array=~\"$array\"}", "legendFormat": "{{array}}" }
      ]
    },
    {
      "id": 3,
      "title": "Active Critical Alerts",
      "type": "stat",
      "description": "Count of active Critical alerts per array (aggregated by severity).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 4, "x": 8, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "value_and_name" },
      "targets": [
        { "refId": "A", "expr": "sum by (array) (powerstore_alert_active{severity=\"Critical\",array=~\"$array\"})", "legendFormat": "{{array}}" }
      ]
    },
    {
      "id": 4,
      "title": "Unhealthy Drives",
      "type": "stat",
      "description": "Count of drives not in Healthy state per array.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "value_and_name" },
      "targets": [
        { "refId": "A", "expr": "sum by (array) (powerstore_drive_state{state!=\"Healthy\",array=~\"$array\"}) or sum by (array) (powerstore_up{array=~\"$array\"} * 0)", "legendFormat": "{{array}}" }
      ]
    },
    {
      "id": 5,
      "title": "Ports Down",
      "type": "stat",
      "description": "Count of ports with link down per array.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "value_and_name" },
      "targets": [
        { "refId": "A", "expr": "sum by (array) (powerstore_port_link_up{array=~\"$array\"} == bool 0)", "legendFormat": "{{array}}" }
      ]
    },
    {
      "id": 6,
      "title": "Bulk API",
      "type": "stat",
      "description": "Whether the bulk performance API path is enabled per array.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "orange", "value": null }, { "color": "green", "value": 1 } ] },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Disabled", "color": "orange" }, "1": { "text": "Enabled", "color": "green" } } }
          ]
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "value_and_name" },
      "targets": [
        { "refId": "A", "expr": "powerstore_array_bulk_api{array=~\"$array\"}", "legendFormat": "{{array}}" }
      ]
    },
    {
      "id": 101,
      "type": "row",
      "title": "Performance glance",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "collapsed": false
    },
    {
      "id": 7,
      "title": "Fleet Total IOPS",
      "type": "stat",
      "description": "Sum of appliance total IOPS per array. Gauge values — aggregate with sum, never rate().",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 7 },
      "fieldConfig": {
        "defaults": {
          "unit": "iops",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": null } ] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area", "textMode": "value_and_name" },
      "targets": [
        { "refId": "A", "expr": "sum by (array) (powerstore_appliance_total_iops{array=~\"$array\"})", "legendFormat": "{{array}}" }
      ]
    },
    {
      "id": 8,
      "title": "Total Bandwidth (read / write)",
      "type": "stat",
      "description": "Aggregate read and write bandwidth across all appliances per array.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 7 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": null } ] }
        },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": "/ read$/" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } } ] },
          { "matcher": { "id": "byRegexp", "options": "/ write$/" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } } ] }
        ]
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area", "textMode": "value_and_name" },
      "targets": [
        { "refId": "A", "expr": "sum by (array) (powerstore_appliance_read_bandwidth_bytes_per_second{array=~\"$array\"})", "legendFormat": "{{array}} read" },
        { "refId": "B", "expr": "sum by (array) (powerstore_appliance_write_bandwidth_bytes_per_second{array=~\"$array\"})", "legendFormat": "{{array}} write" }
      ]
    },
    {
      "id": 9,
      "title": "Avg Latency (read / write)",
      "type": "stat",
      "description": "Average read and write latency across all appliances per array.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 7 },
      "fieldConfig": {
        "defaults": {
          "unit": "µs",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1000 }, { "color": "red", "value": 3000 } ] }
        },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": "/ read$/" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } } ] },
          { "matcher": { "id": "byRegexp", "options": "/ write$/" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } } ] }
        ]
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area", "textMode": "value_and_name" },
      "targets": [
        { "refId": "A", "expr": "avg by (array) (powerstore_appliance_read_latency_microseconds{array=~\"$array\"})", "legendFormat": "{{array}} read" },
        { "refId": "B", "expr": "avg by (array) (powerstore_appliance_write_latency_microseconds{array=~\"$array\"})", "legendFormat": "{{array}} write" }
      ]
    },
    {
      "id": 102,
      "type": "row",
      "title": "Capacity glance",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "collapsed": false
    },
    {
      "id": 10,
      "title": "Cluster Capacity Used %",
      "type": "gauge",
      "description": "Cluster physical used / physical total across the selected arrays.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 85 } ] },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "refId": "A", "expr": "100 * sum by (array) (powerstore_cluster_physical_used_bytes{array=~\"$array\"}) / sum by (array) (powerstore_cluster_physical_total_bytes{array=~\"$array\"})", "legendFormat": "{{array}}" }
      ]
    },
    {
      "id": 11,
      "title": "Data Reduction Ratio",
      "type": "stat",
      "description": "Cluster data-reduction ratio (N:1).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 2, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "textMode": "auto" },
      "targets": [
        { "refId": "A", "expr": "avg by (array) (powerstore_cluster_data_reduction_ratio{array=~\"$array\"})", "legendFormat": "{{array}}" }
      ]
    }
  ]
}
