# Copy to .env and fill in — `.env` is gitignored, never commit real secrets.
# Compose reads .env natively, and the pstore_exporter binary itself loads .env
# from the working directory (or next to config.yaml). Already-set environment
# variables always take precedence over .env values.

# PowerStore management IP or FQDN for the first array.
# config.yaml references it as ${PSTORE1_HOSTNAME}.
PSTORE1_HOSTNAME=10.0.0.1

# Username for the PowerStore monitoring account.
# config.yaml references it as ${PSTORE1_USERNAME}.
PSTORE1_USERNAME=admin

# Password for the PowerStore monitoring account.
# config.yaml references it as ${PSTORE1_PASSWORD}.
PSTORE1_PASSWORD=changeme
