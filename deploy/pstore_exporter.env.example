# EnvironmentFile for the pstore_exporter systemd unit.
# Supplies array secrets referenced as ${VAR} in config.yaml.
#
# Install:  /etc/pstore_exporter/pstore_exporter.env   (chmod 0600, chown root:pstore)

PSTORE1_PASSWORD=change-me
# PSTORE2_PASSWORD=change-me

# Skip TLS certificate verification (INSECURE — trusted network / self-signed
# certs only). Referenced as ${PSTORE1_SKIP_CERTIFICATE} in config.yaml.
PSTORE1_SKIP_CERTIFICATE=false
# PSTORE2_SKIP_CERTIFICATE=false
